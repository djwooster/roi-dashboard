# Stripe
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...          # Price ID from Stripe dashboard for your main plan
BILLING_ENFORCEMENT=false          # Set to "true" at launch to redirect inactive orgs to /billing

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=https://sourceiq.app

# Meta / Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=        # Used for OAuth token exchange AND signed_request verification (data deletion webhook)

# Meta founder account fallback (system user token — not needed for customer OAuth flow)
META_FOUNDER_BUSINESS_ID=
META_FOUNDER_ACCOUNT_ID=

# Google Ads
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GoHighLevel
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=

# Anthropic (AI summary on report page)
ANTHROPIC_API_KEY=sk-ant-...

# Cron (background sync — Vercel injects this as Authorization: Bearer <secret>)
CRON_SECRET=

# HubSpot
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# Jobber
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
